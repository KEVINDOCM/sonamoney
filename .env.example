# ============================================
# SonaMoney - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.io
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Google Site Verification (for SEO)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Optional: App URL (for metadata and SEO)
NEXT_PUBLIC_APP_URL=https://sonamoney.my.id

# Request Signature Secret (SERVER-SIDE ONLY - for HMAC-SHA256 payload signing)
# Generate with: openssl rand -base64 32
# ⚠️ CRITICAL: This is now SERVER-ONLY. Never prefix with NEXT_PUBLIC_
# The client no longer signs requests - authentication is via Supabase session
REQUEST_SECRET=your-generated-secret-key-here

# ============================================
# Redis Configuration (Upstash) - For Distributed Rate Limiting
# Sign up at https://upstash.com/ and create a Redis database
# Required for CR-002: Scalable rate limiting across multiple instances
# Falls back to in-memory if not configured (non-scalable)
# ============================================
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ============================================
# Cloudflare Turnstile CAPTCHA (Optional)
# Sign up at https://dash.cloudflare.com/ > Turnstile
# Required for bot protection on login/register
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAx
TURNSTILE_SECRET_KEY=0x4AAAAAAAx

# ============================================
# Admin IP Whitelist (comma-separated)
# Used for maintenance mode bypass
# Example: MAINTENANCE_ADMIN_IPS=192.168.1.1,10.0.0.5
# ============================================
MAINTENANCE_ADMIN_IPS=

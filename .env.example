# ============================================
# SonaMoney - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# Supabase Configuration
# Get these from your Supabase project dashboard: https://app.supabase.io
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Google Site Verification (for SEO)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Optional: App URL (for metadata and SEO)
NEXT_PUBLIC_APP_URL=https://sonamoney.my.id

# Request Signature Secret (for HMAC-SHA256 payload signing)
# Generate with: openssl rand -base64 32
# This must be identical on both client and server for request integrity
NEXT_PUBLIC_REQUEST_SECRET=your-generated-secret-key-here
